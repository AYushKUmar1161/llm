# ============================================================
# CodeForge AI — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Application ──────────────────────────────────────────────
APP_ENV=development
APP_NAME=CodeForge AI
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
DEBUG=true

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=codeforge
POSTGRES_PASSWORD=codeforge_secret
POSTGRES_DB=codeforge_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://codeforge:codeforge_secret@postgres:5432/codeforge_db

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── ChromaDB ─────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ── LLM Providers (at least ONE required) ───────────────────
# Default provider: openai | gemini | anthropic | ollama
DEFAULT_LLM_PROVIDER=openai

OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

GOOGLE_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-1.5-pro

ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama (for local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── GitHub OAuth ─────────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/callback/github

# ── LangSmith (AI Observability — free tier available) ───────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-key-here
LANGCHAIN_PROJECT=codeforge-ai

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Repository Storage ───────────────────────────────────────
REPOS_BASE_PATH=/app/repos
MAX_REPO_SIZE_MB=500

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=1000

# ── Monitoring ───────────────────────────────────────────────
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=CodeForge AI
