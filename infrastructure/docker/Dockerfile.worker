FROM python:3.12-slim

RUN apt-get update && apt-get install -y \
    git \
    curl \
    build-essential \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

RUN mkdir -p /app/repos

RUN useradd --create-home --shell /bin/bash codeforge
RUN chown -R codeforge:codeforge /app
USER codeforge

# Default: run Celery worker (can be overridden for beat)
CMD ["celery", "-A", "app.tasks.celery_app", "worker", "--loglevel=info", "--concurrency=4", "-Q", "default,indexing,agents"]
